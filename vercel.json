{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "installCommand": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/demo", "destination": "/demo.html" },
    { "source": "/demo.html", "destination": "/demo.html" },
    { "source": "/style.css", "destination": "/style.css" },
    { "source": "/script.js", "destination": "/script.js" },
    { "source": "/server.cjs", "destination": "/server.cjs" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
